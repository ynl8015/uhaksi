generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AccountKind {
  STUDENT
  OTHER
}

enum CommunityCategory {
  QA
  STUDY_TIP
  STUDY_PROOF
}

model School {
  id             Int      @id @default(autoincrement())
  name           String
  address        String?
  neisRegionCode String?
  neisCode       String?
  createdAt      DateTime @default(now())

  exams          Exam[]
  examReviews    ExamReview[]
  reviewAggs     ExamReviewAggregate[]

  @@unique([name, address])
  @@unique([neisRegionCode, neisCode])
  @@index([name])
  @@index([address])
}

model Exam {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  title     String
  startDate DateTime
  endDate   DateTime
  createdAt DateTime @default(now())

  school        School         @relation(fields: [schoolId], references: [id])
  subjects      ExamSubject[]
  subjectRanges SubjectRange[]
}

model ExamSubject {
  id      Int     @id @default(autoincrement())
  examId  Int
  date    String?
  grade   Int?
  period  Int?
  subject String

  exam    Exam    @relation(fields: [examId], references: [id])
}

model SubjectRange {
  id       Int    @id @default(autoincrement())
  examId   Int
  grade    Int?
  subject  String
  label    String?
  content  String?
  sortOrder Int  @default(0)

  exam     Exam   @relation(fields: [examId], references: [id])

  @@index([examId, grade, subject])
}

model User {
  id            Int       @id @default(autoincrement())
  loginId       String    @unique
  email         String    @unique
  password      String
  name          String
  emailVerified Boolean   @default(false)
  verifyToken   String?
  passwordResetToken   String?   @unique
  passwordResetExpires DateTime?
  createdAt     DateTime  @default(now())

  accountKind         AccountKind @default(OTHER)
  studentVerifiedAt   DateTime?
  verifiedSchoolName  String?
  isAdmin             Boolean     @default(false)

  examReviews                ExamReview[]
  studentCommunityPosts      StudentCommunityPost[]
  studentCommunityComments   StudentCommunityComment[]
}

model ExamReview {
  id               Int      @id @default(autoincrement())
  schoolId         Int
  examTitle        String
  grade            Int
  createdByUserId  Int

  difficulty       Int      // 1..5
  grammarCount     Int?     // 문법
  vocabCount       Int?     // 어휘
  readingCount     Int?     // 독해
  writingCount     Int?     // 서술형/주관식
  listeningCount   Int?     // 듣기(있으면)
  otherCount       Int?     // 기타

  freeText         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  school           School   @relation(fields: [schoolId], references: [id])
  createdBy        User     @relation(fields: [createdByUserId], references: [id])

  @@index([schoolId, examTitle, grade])
  @@index([createdByUserId])
  @@unique([schoolId, examTitle, grade, createdByUserId])
}

model ExamReviewAggregate {
  id            Int      @id @default(autoincrement())
  schoolId      Int
  examTitle     String
  grade         Int

  windowStart   DateTime
  windowEnd     DateTime

  sourceCount   Int
  statsJson     Json

  aiSummary     String?
  aiModel       String?
  aiGeneratedAt DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  school        School   @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, examTitle, grade])
  @@index([schoolId, examTitle, grade])
}

model StudentCommunityPost {
  id        Int               @id @default(autoincrement())
  userId    Int
  category  CommunityCategory
  title     String?
  body      String
  imageData String?           @db.Text
  createdAt DateTime          @default(now())

  user     User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments StudentCommunityComment[]

  @@index([category, createdAt])
  @@index([userId])
}

model StudentCommunityComment {
  id        Int      @id @default(autoincrement())
  postId    Int
  userId    Int
  body      String
  createdAt DateTime @default(now())

  post StudentCommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([userId])
}